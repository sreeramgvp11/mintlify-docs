{
  "info": {
    "name": "HydraDB API",
    "description": "Complete HydraDB API collection — generated from api.hydradb.com/openapi.json and verified against docs. Base URL: https://api.hydradb.com. Auth: Bearer token in Authorization header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{HYDRADB_API_KEY}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "https://api.hydradb.com" },
    { "key": "HYDRADB_API_KEY", "value": "YOUR_API_KEY_HERE" },
    { "key": "tenant_id", "value": "my_first_tenant" },
    { "key": "sub_tenant_id", "value": "user_alex_123" },
    { "key": "source_id", "value": "" },
    { "key": "memory_id", "value": "" }
  ],
  "item": [
    {
      "name": "Tenants",
      "item": [
        {
          "name": "Create Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/tenants/create", "host": ["{{base_url}}"], "path": ["tenants", "create"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"tenant_metadata_schema\": [\n    {\n      \"name\": \"category\",\n      \"data_type\": \"VARCHAR\",\n      \"max_length\": 256,\n      \"enable_match\": true\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Check Infra Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tenants/infra/status?tenant_id={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["tenants", "infra", "status"],
              "query": [{ "key": "tenant_id", "value": "{{tenant_id}}" }]
            }
          }
        },
        {
          "name": "Monitor Tenant",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tenants/monitor?tenant_id={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["tenants", "monitor"],
              "query": [{ "key": "tenant_id", "value": "{{tenant_id}}" }]
            }
          }
        },
        {
          "name": "List Tenant IDs",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/tenants/tenant_ids", "host": ["{{base_url}}"], "path": ["tenants", "tenant_ids"] }
          }
        },
        {
          "name": "List Sub-Tenant IDs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tenants/sub_tenant_ids?tenant_id={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["tenants", "sub_tenant_ids"],
              "query": [{ "key": "tenant_id", "value": "{{tenant_id}}" }]
            }
          }
        },
        {
          "name": "Delete Tenant",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/tenants/delete?tenant_id={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["tenants", "delete"],
              "query": [{ "key": "tenant_id", "value": "{{tenant_id}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Ingestion — Knowledge",
      "item": [
        {
          "name": "Upload Knowledge (File)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/ingestion/upload_knowledge", "host": ["{{base_url}}"], "path": ["ingestion", "upload_knowledge"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "tenant_id", "value": "{{tenant_id}}", "type": "text" },
                { "key": "files", "type": "file", "src": [] },
                { "key": "file_metadata", "value": "[{\"file_id\": \"doc_001\", \"metadata\": {\"category\": \"engineering\"}, \"additional_metadata\": {\"author\": \"Alice\"}}]", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Upload Knowledge (App Sources)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/ingestion/upload_knowledge", "host": ["{{base_url}}"], "path": ["ingestion", "upload_knowledge"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "tenant_id", "value": "{{tenant_id}}", "type": "text" },
                { "key": "app_sources", "value": "[{\"id\": \"slack_001\", \"title\": \"Q4 Planning\", \"type\": \"slack\", \"content\": {\"text\": \"We agreed on three tiers...\"}, \"metadata\": {\"category\": \"planning\"}, \"additional_metadata\": {\"channel\": \"#product\"}}]", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Verify Processing",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/ingestion/verify_processing?file_ids={{source_id}}&tenant_id={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["ingestion", "verify_processing"],
              "query": [
                { "key": "file_ids", "value": "{{source_id}}" },
                { "key": "tenant_id", "value": "{{tenant_id}}" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Ingestion — Memories",
      "item": [
        {
          "name": "Add Memory (Plain Text)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/memories/add_memory", "host": ["{{base_url}}"], "path": ["memories", "add_memory"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"sub_tenant_id\": \"{{sub_tenant_id}}\",\n  \"memories\": [\n    {\n      \"text\": \"User prefers detailed technical explanations and dark mode\",\n      \"infer\": true,\n      \"user_name\": \"Alex\",\n      \"metadata\": { \"team\": \"engineering\" },\n      \"additional_metadata\": { \"source\": \"onboarding\" }\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Add Memory (Conversation Pairs)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/memories/add_memory", "host": ["{{base_url}}"], "path": ["memories", "add_memory"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"sub_tenant_id\": \"{{sub_tenant_id}}\",\n  \"memories\": [\n    {\n      \"user_assistant_pairs\": [\n        { \"user\": \"I prefer dark mode\", \"assistant\": \"Noted.\" },\n        { \"user\": \"Keep answers concise\", \"assistant\": \"Understood.\" }\n      ],\n      \"infer\": true,\n      \"user_name\": \"Alex\"\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Delete Memory",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/memories/delete_memory?tenant_id={{tenant_id}}&memory_id={{memory_id}}",
              "host": ["{{base_url}}"],
              "path": ["memories", "delete_memory"],
              "query": [
                { "key": "tenant_id", "value": "{{tenant_id}}" },
                { "key": "memory_id", "value": "{{memory_id}}" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Recall",
      "item": [
        {
          "name": "Full Recall (Knowledge)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/recall/full_recall", "host": ["{{base_url}}"], "path": ["recall", "full_recall"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"query\": \"What are the pricing tiers?\",\n  \"max_results\": 5,\n  \"mode\": \"thinking\",\n  \"graph_context\": true,\n  \"metadata_filters\": { \"category\": \"pricing\" }\n}"
            }
          }
        },
        {
          "name": "Recall Preferences (Memories)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/recall/recall_preferences", "host": ["{{base_url}}"], "path": ["recall", "recall_preferences"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"sub_tenant_id\": \"{{sub_tenant_id}}\",\n  \"query\": \"answer style and tone preferences\",\n  \"mode\": \"thinking\",\n  \"max_results\": 3\n}"
            }
          }
        },
        {
          "name": "Boolean Recall",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/recall/boolean_recall", "host": ["{{base_url}}"], "path": ["recall", "boolean_recall"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"query\": \"ERROR_429 rate limit\",\n  \"operator\": \"and\",\n  \"max_results\": 10,\n  \"search_mode\": \"sources\"\n}"
            }
          }
        },
      ]
    },
    {
      "name": "Knowledge Deletion",
      "item": [
        {
          "name": "Delete Knowledge",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/knowledge/delete_knowledge", "host": ["{{base_url}}"], "path": ["knowledge", "delete_knowledge"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"ids\": [\"{{source_id}}\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "List & Fetch",
      "item": [
        {
          "name": "List Data (Knowledge)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/list/data", "host": ["{{base_url}}"], "path": ["list", "data"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"kind\": \"knowledge\",\n  \"page\": 1,\n  \"page_size\": 25,\n  \"filters\": {\n    \"metadata\": { \"category\": \"engineering\" }\n  }\n}"
            }
          }
        },
        {
          "name": "List Data (Memories)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/list/data", "host": ["{{base_url}}"], "path": ["list", "data"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"sub_tenant_id\": \"{{sub_tenant_id}}\",\n  \"kind\": \"memories\",\n  \"page\": 1,\n  \"page_size\": 25\n}"
            }
          }
        },
        {
          "name": "Fetch Content",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/fetch/content", "host": ["{{base_url}}"], "path": ["fetch", "content"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"source_id\": \"{{source_id}}\",\n  \"mode\": \"url\",\n  \"expiry_seconds\": 3600\n}"
            }
          }
        },
        {
          "name": "Graph Relations By Source ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/list/graph_relations_by_id?source_id={{source_id}}&tenant_id={{tenant_id}}&limit=100",
              "host": ["{{base_url}}"],
              "path": ["list", "graph_relations_by_id"],
              "query": [
                { "key": "source_id", "value": "{{source_id}}" },
                { "key": "tenant_id", "value": "{{tenant_id}}" },
                { "key": "limit", "value": "100" }
              ]
            }
          }
        }
      ]
    }
  ]
}
