{
  "openapi": "3.1.0",
  "info": {
    "title": "HydraDB API",
    "version": "2.0.0",
    "description": "HydraDB API reference. Send `API-Version: 2` with each request."
  },
  "servers": [
    {
      "url": "https://api.hydradb.com",
      "description": "Production"
    }
  ],
  "paths": {
    "/tenants": {
      "post": {
        "tags": [
          "Tenants"
        ],
        "summary": "Create a tenant",
        "x-fern-sdk-group-name": "tenants",
        "x-fern-sdk-method-name": "create",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "Create a new tenant and provision its infrastructure.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TenantCreateRequest"
              },
              "example": {
                "tenant_id": "my_first_tenant",
                "tenant_metadata_schema": [
                  {
                    "name": "department",
                    "data_type": "string",
                    "enable_match": true
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          },
          "400": {
            "$ref": "#/components/responses/V2Error"
          },
          "422": {
            "$ref": "#/components/responses/V2Error"
          }
        }
      },
      "get": {
        "tags": [
          "Tenants"
        ],
        "summary": "List tenants",
        "x-fern-sdk-group-name": "tenants",
        "x-fern-sdk-method-name": "list",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "List all tenant IDs registered for the authenticated organization.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          },
          "401": {
            "$ref": "#/components/responses/V2Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Tenants"
        ],
        "summary": "Delete a tenant",
        "x-fern-sdk-group-name": "tenants",
        "x-fern-sdk-method-name": "delete",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "Delete a tenant and all associated infrastructure and data. This action is irreversible.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          },
          {
            "$ref": "#/components/parameters/TenantIdQuery"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          },
          "404": {
            "$ref": "#/components/responses/V2Error"
          }
        }
      }
    },
    "/tenants/status": {
      "get": {
        "tags": [
          "Tenants"
        ],
        "summary": "Get tenant infrastructure status",
        "x-fern-sdk-group-name": "tenants",
        "x-fern-sdk-method-name": "status",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "Check the provisioning status of a tenant's infrastructure.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          },
          {
            "$ref": "#/components/parameters/TenantIdQuery"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          },
          "404": {
            "$ref": "#/components/responses/V2Error"
          }
        }
      }
    },
    "/tenants/sub-tenants": {
      "get": {
        "tags": [
          "Tenants"
        ],
        "summary": "List sub-tenants",
        "x-fern-sdk-group-name": "tenants",
        "x-fern-sdk-method-name": "sub_tenants",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "List unique sub-tenant IDs that have indexed data.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          },
          {
            "$ref": "#/components/parameters/TenantIdQuery"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          }
        }
      }
    },
    "/tenants/stats": {
      "get": {
        "tags": [
          "Tenants"
        ],
        "summary": "Get tenant stats",
        "x-fern-sdk-group-name": "tenants",
        "x-fern-sdk-method-name": "stats",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "Retrieve usage statistics such as object count and vector dimension for a tenant.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          },
          {
            "$ref": "#/components/parameters/TenantIdQuery"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          }
        }
      }
    },
    "/source/ingest": {
      "post": {
        "tags": [
          "Source"
        ],
        "summary": "Ingest content",
        "x-fern-sdk-group-name": "source",
        "x-fern-sdk-method-name": "ingest",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "Unified ingestion endpoint for knowledge and memory. Use `type` to choose `knowledge` or `memory`.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/IngestRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "$ref": "#/components/responses/V2Success"
          },
          "400": {
            "$ref": "#/components/responses/V2Error"
          },
          "422": {
            "$ref": "#/components/responses/V2Error"
          }
        }
      }
    },
    "/source/status": {
      "get": {
        "tags": [
          "Source"
        ],
        "summary": "Check processing status",
        "x-fern-sdk-group-name": "source",
        "x-fern-sdk-method-name": "status",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "Check the processing status of ingested documents or memories by ID.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          },
          {
            "name": "file_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Single source or file ID to check."
          },
          {
            "name": "file_ids",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "One or more source or file IDs to check."
          },
          {
            "$ref": "#/components/parameters/TenantIdQueryOptional"
          },
          {
            "$ref": "#/components/parameters/SubTenantIdQuery"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          }
        }
      }
    },
    "/source/fetch": {
      "get": {
        "tags": [
          "Source"
        ],
        "summary": "Fetch document content",
        "x-fern-sdk-group-name": "source",
        "x-fern-sdk-method-name": "fetch",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "Retrieve the content of a previously ingested document or memory.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          },
          {
            "name": "source_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Source ID of the document or memory to fetch."
          },
          {
            "$ref": "#/components/parameters/TenantIdQuery"
          },
          {
            "$ref": "#/components/parameters/SubTenantIdQuery"
          },
          {
            "name": "mode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "content",
                "url",
                "both"
              ],
              "default": "content"
            },
            "description": "Fetch mode."
          },
          {
            "name": "expiry_seconds",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 60,
              "maximum": 604800,
              "default": 3600
            },
            "description": "Presigned URL expiry in seconds."
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          },
          "404": {
            "$ref": "#/components/responses/V2Error"
          }
        }
      }
    },
    "/source/list": {
      "post": {
        "tags": [
          "Source"
        ],
        "summary": "List documents",
        "x-fern-sdk-group-name": "source",
        "x-fern-sdk-method-name": "list",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "List knowledge sources or memories with pagination and optional filters.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListContentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          },
          "422": {
            "$ref": "#/components/responses/V2Error"
          }
        }
      }
    },
    "/source": {
      "delete": {
        "tags": [
          "Source"
        ],
        "summary": "Delete documents or memories",
        "x-fern-sdk-group-name": "source",
        "x-fern-sdk-method-name": "delete",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "Unified deletion endpoint for knowledge documents and memories. Use `type` to choose `knowledge` or `memory`.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeleteDocumentBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          },
          "404": {
            "$ref": "#/components/responses/V2Error"
          }
        }
      }
    },
    "/source/relations": {
      "get": {
        "tags": [
          "Source"
        ],
        "summary": "Get graph relations",
        "x-fern-sdk-group-name": "source",
        "x-fern-sdk-method-name": "relations",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "Retrieve knowledge graph relations for a specific source or across a sub-tenant.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          },
          {
            "$ref": "#/components/parameters/TenantIdQuery"
          },
          {
            "name": "source_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Source ID. If omitted, returns relations across the sub-tenant."
          },
          {
            "name": "is_memory",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Whether to fetch relations for memories."
          },
          {
            "$ref": "#/components/parameters/SubTenantIdQuery"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000,
              "default": 5000
            },
            "description": "Maximum number of relation groups to return."
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Pagination cursor from a previous response."
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          }
        }
      }
    },
    "/search": {
      "post": {
        "tags": [
          "Search"
        ],
        "summary": "Search",
        "x-fern-sdk-group-name": "search",
        "x-fern-sdk-method-name": "query",
        "x-fern-sdk-audience": [
          "v2"
        ],
        "description": "Unified search endpoint for retrieval over documents, memories, or both.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersionHeader"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              },
              "example": {
                "tenant_id": "my_first_tenant",
                "query": "What are the pricing tiers?",
                "source": "knowledge",
                "search_by": "hybrid",
                "max_results": 5
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/V2Success"
          },
          "400": {
            "$ref": "#/components/responses/V2Error"
          },
          "422": {
            "$ref": "#/components/responses/V2Error"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "ApiVersionHeader": {
        "name": "API-Version",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "enum": [
            "2"
          ],
          "default": "2"
        },
        "description": "Use `2` to call this API contract."
      },
      "TenantIdQuery": {
        "name": "tenant_id",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Tenant ID."
      },
      "TenantIdQueryOptional": {
        "name": "tenant_id",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Tenant ID."
      },
      "SubTenantIdQuery": {
        "name": "sub_tenant_id",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Optional sub-tenant scope."
      }
    },
    "responses": {
      "V2Success": {
        "description": "Successful response.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/V2Envelope"
            },
            "example": {
              "success": true,
              "data": {},
              "error": null,
              "meta": {
                "request_id": "9d13aef4-02f4-4e73-8c62-4c2601d04f9d",
                "latency_ms": 12.3
              }
            }
          }
        }
      },
      "V2Error": {
        "description": "Error response.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/V2Envelope"
            },
            "example": {
              "success": false,
              "data": null,
              "error": {
                "code": "VALIDATION_ERROR",
                "message": "Request validation failed"
              },
              "meta": {
                "request_id": "9d13aef4-02f4-4e73-8c62-4c2601d04f9d",
                "latency_ms": 4.8
              }
            }
          }
        }
      }
    },
    "schemas": {
      "V2Envelope": {
        "type": "object",
        "required": [
          "success",
          "data",
          "error",
          "meta"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "example": true,
            "description": "Whether the request was successful. `true` for 2xx responses, `false` for errors."
          },
          "data": {
            "description": "Endpoint-specific response payload.",
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": true
              },
              {
                "type": "array",
                "items": {}
              },
              {
                "type": "null"
              }
            ]
          },
          "error": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/V2ErrorBody"
              },
              {
                "type": "null"
              }
            ],
            "description": "Error message if failed"
          },
          "meta": {
            "$ref": "#/components/schemas/V2Meta",
            "description": "Response metadata such as request identifiers and server-side latency."
          }
        }
      },
      "V2ErrorBody": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Machine-readable error code (e.g., `TENANT_NOT_FOUND`, `VALIDATION_ERROR`)."
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message explaining what went wrong."
          }
        }
      },
      "V2Meta": {
        "type": "object",
        "properties": {
          "request_id": {
            "type": "string",
            "description": "Unique identifier for this request. Include in support tickets to help locate logs."
          },
          "latency_ms": {
            "type": "number",
            "description": "Server-side processing latency in milliseconds."
          }
        }
      },
      "TenantCreateRequest": {
        "type": "object",
        "required": [
          "tenant_id"
        ],
        "properties": {
          "tenant_id": {
            "type": "string",
            "example": "my_first_tenant",
            "description": "Unique tenant identifier"
          },
          "tenant_metadata_schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MetadataField"
            },
            "description": "Optional tenant-level metadata schema. Define fields here when you want to filter or search consistently by metadata later, such as department, region, plan, customer tier, product area, or compliance framework. These fields become part of the tenant's searchable/filterable contract and should be stable."
          },
          "is_embeddings_tenant": {
            "type": "boolean",
            "default": false,
            "description": "True to create embeddings tenant",
            "example": true
          },
          "embeddings_dimension": {
            "type": "integer",
            "example": 1536,
            "description": "Embedding dimensions for embeddings tenant. Not required for non-embeddings (is_embeddings_tenant=False) tenants"
          }
        }
      },
      "MetadataField": {
        "type": "object",
        "description": "A metadata field definition for tenant-level filtering or search.",
        "properties": {
          "name": {
            "type": "string",
            "example": "department",
            "description": "Metadata key to define. Use the same key when ingesting source metadata and when filtering search results."
          },
          "data_type": {
            "type": "string",
            "example": "string",
            "description": "Value type for this metadata field. Friendly values include string, integer, float, boolean, array, and object."
          },
          "max_length": {
            "type": "integer",
            "default": 1024,
            "description": "Maximum length for string fields."
          },
          "enable_analyzer": {
            "type": "boolean",
            "default": false,
            "description": "Enable text analysis for this field."
          },
          "enable_match": {
            "type": "boolean",
            "default": false,
            "description": "Enable exact-match filtering on this field. Use this for metadata filters like department, region, customer_tier, or category."
          },
          "enable_dense_embedding": {
            "type": "boolean",
            "default": false,
            "description": "Enable semantic search over this field. Only applicable to string/VARCHAR fields."
          },
          "enable_sparse_embedding": {
            "type": "boolean",
            "default": false,
            "description": "Enable keyword/BM25 search over this field. Only applicable to string/VARCHAR fields."
          },
          "nullable": {
            "type": "boolean",
            "default": true,
            "description": "Whether this metadata field may be omitted or null."
          }
        }
      },
      "IngestRequest": {
        "type": "object",
        "required": [
          "tenant_id"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "knowledge",
              "memory"
            ],
            "default": "knowledge",
            "description": "Type of content to ingest. Use knowledge for shared source material such as PDFs, docs, app pages, tickets, Slack threads, or webpages. Use memory for user-specific context such as preferences, conversation history, notes, or inferred traits."
          },
          "tenant_id": {
            "type": "string",
            "example": "my_first_tenant",
            "description": "Unique identifier for the tenant/organization"
          },
          "sub_tenant_id": {
            "type": "string",
            "example": "default",
            "description": "Optional sub-tenant identifier used to organize data within a tenant. If omitted, the default sub-tenant created during tenant setup will be used."
          },
          "upsert": {
            "type": "boolean",
            "default": true,
            "description": "If true, update existing sources with the same id.",
            "example": true
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "binary"
            },
            "description": "Files to upload when `type` is `knowledge`. Use this for PDFs, docs, CSVs, markdown files, and other documents HydraDB should parse and index."
          },
          "file_metadata": {
            "type": "string",
            "description": "JSON string containing an array of metadata objects, one per uploaded file in the same order as `files`. Use this to set stable `file_id`/source IDs, tenant-level metadata for filtering, document-level metadata for display, or forceful relations. Use tenant metadata for fields you want to filter/search across many sources, like department or region; use document metadata for per-source display details like author, filename, version, or created_at."
          },
          "app_knowledge": {
            "type": "string",
            "description": "JSON string containing one app-generated source object or an array of sources. Use this when your app has already extracted text and metadata from systems like Slack, Notion, Gmail, tickets, or webpages."
          },
          "memories": {
            "type": "string",
            "description": "JSON string containing an array of memory items when `type` is `memory`. Each memory should include either `text` or `user_assistant_pairs` and is intended for user-specific personalization."
          }
        }
      },
      "ListContentRequest": {
        "type": "object",
        "required": [
          "tenant_id"
        ],
        "properties": {
          "tenant_id": {
            "type": "string",
            "description": "Tenant ID",
            "example": "tenant_1234"
          },
          "sub_tenant_id": {
            "type": "string",
            "description": "Sub-tenant ID",
            "example": "sub_tenant_4567"
          },
          "kind": {
            "type": "string",
            "enum": [
              "knowledge",
              "memories"
            ],
            "default": "knowledge",
            "description": "Choose whether to list shared knowledge sources or user memories."
          },
          "source_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional list of source IDs to fetch. Source IDs come from `/source/ingest` responses, from your own `file_id` values in `file_metadata`, or from previous `/source/list` calls. Pass this when you want a known subset instead of paginating through all sources."
          },
          "page": {
            "type": "integer",
            "default": 1,
            "description": "Page number to retrieve (1-indexed). Defaults to 1.",
            "example": 1
          },
          "page_size": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50,
            "description": "Number of items per page (1-100). Defaults to 50.",
            "example": 1
          },
          "filters": {
            "$ref": "#/components/schemas/ContentFilter",
            "description": "Optional filters. Provide key-value pairs to match against tenant_metadata, document_metadata, and/or source-level fields (title, type, description, url, timestamp)."
          },
          "include_fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional list of source fields to include in the response. Use this to reduce payload size when you only need fields such as title, type, url, timestamp, tenant_metadata, or document_metadata."
          }
        }
      },
      "ContentFilter": {
        "type": "object",
        "description": "Optional filters. All provided filters are ANDed together.",
        "properties": {
          "tenant_metadata": {
            "type": "object",
            "additionalProperties": true,
            "description": "Key-value pairs matched against source tenant metadata. Use tenant metadata for fields you want to filter/search across many sources, like department, region, customer_tier, or category."
          },
          "document_metadata": {
            "type": "object",
            "additionalProperties": true,
            "description": "Key-value pairs matched against source document metadata. Use document metadata for per-source details you mainly want to display or inspect, like author, filename, version, or created_at."
          },
          "source_fields": {
            "type": "object",
            "additionalProperties": true,
            "description": "Key-value pairs matched against filterable source fields: title, type, description, url, timestamp."
          }
        }
      },
      "DeleteDocumentBody": {
        "type": "object",
        "required": [
          "request"
        ],
        "properties": {
          "request": {
            "$ref": "#/components/schemas/DeleteContentRequest",
            "description": "Delete payload containing `tenant_id`, `sub_tenant_id` (optional), and `ids`. See DeleteContentRequest."
          },
          "type": {
            "type": "string",
            "enum": [
              "knowledge",
              "memory"
            ],
            "default": "knowledge",
            "description": "Type of content to delete."
          }
        }
      },
      "DeleteContentRequest": {
        "type": "object",
        "required": [
          "tenant_id",
          "ids"
        ],
        "properties": {
          "tenant_id": {
            "type": "string",
            "description": "Unique identifier for the tenant/organization",
            "example": "tenant_1234"
          },
          "sub_tenant_id": {
            "type": "string",
            "description": "Optional sub-tenant identifier used to organize data within a tenant. If omitted, the default sub-tenant created during tenant setup will be used.",
            "example": "sub_tenant_4567"
          },
          "ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "HydraDoc1234",
              "HydraDoc4567"
            ],
            "description": "One or more source IDs to delete. At least one is required."
          }
        }
      },
      "SearchRequest": {
        "type": "object",
        "required": [
          "tenant_id",
          "query"
        ],
        "properties": {
          "tenant_id": {
            "type": "string",
            "example": "my_first_tenant",
            "description": "Unique identifier for the tenant/organization"
          },
          "sub_tenant_id": {
            "type": "string",
            "example": "default",
            "description": "Optional sub-tenant identifier used to organize data within a tenant. If omitted, the default sub-tenant created during tenant setup will be used."
          },
          "query": {
            "type": "string",
            "example": "What are the pricing tiers?",
            "description": "Search terms to find in your content"
          },
          "source": {
            "type": "string",
            "enum": [
              "knowledge",
              "memories",
              "all"
            ],
            "default": "knowledge",
            "description": "What to search."
          },
          "search_by": {
            "type": "string",
            "enum": [
              "hybrid",
              "text",
              "vector"
            ],
            "default": "hybrid",
            "description": "Search method."
          },
          "operator": {
            "type": "string",
            "enum": [
              "or",
              "and",
              "phrase"
            ],
            "default": "or",
            "description": "Text search operator for `search_by: text`."
          },
          "max_results": {
            "type": "integer",
            "minimum": 1,
            "example": 5,
            "description": "Maximum number of chunks to return. Server picks a sensible default when omitted; start with 10 and tune from there."
          },
          "mode": {
            "type": "string",
            "enum": [
              "fast",
              "thinking"
            ],
            "default": "fast",
            "description": "Retrieval pipeline. `fast` runs a single query pass \u2014 lowest latency, good for real-time chat and autocomplete. `thinking` expands the query into multiple sub-queries, reranks the combined results, and pulls in author-declared `search_forceful_relations` as `additional_context`. Higher quality, higher latency. Applies to `search_by: \"hybrid\"` and `\"vector\"` only; ignored for `\"text\"`."
          },
          "alpha": {
            "oneOf": [
              {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              {
                "type": "string",
                "enum": [
                  "auto"
                ]
              }
            ],
            "default": 0.8,
            "description": "Hybrid weight. `1.0` = pure semantic (dense vectors), `0.0` = pure BM25 (keyword), values in between blend the two. `\"auto\"` lets HydraDB pick per query. Applies to `search_by: \"hybrid\"` only \u2014 ignored for `\"text\"` and `\"vector\"`."
          },
          "recency_bias": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "default": 0.0,
            "description": "Boost for newer content. `0.0` applies no recency preference (default). `1.0` strongly prefers recent items. Tune to `0.2\u20130.4` for mixed content, `0.6\u20130.8` for changelogs, news, or status updates."
          },
          "graph_context": {
            "type": "boolean",
            "default": false,
            "description": "When `true`, includes the entity/relation graph slice for retrieved chunks in the response under `graph_context` (with `query_paths`, `chunk_relations`, and `chunk_id_to_group_ids`). Off by default \u2014 turn on when you need to show how things connect, not just what is similar."
          },
          "search_forceful_relations": {
            "type": "boolean",
            "default": true,
            "description": "Whether to pull author-declared related sources (set at ingest via the per-item `relations.cortex_source_ids`) into the response's `additional_context` field. **Only takes effect when `mode: \"thinking\"`** \u2014 silently ignored in `fast` mode."
          },
          "additional_context": {
            "type": "string",
            "description": "Free-form text to bias retrieval. Example: \"User is on the billing page\" or \"User is on the Pro plan\". Keep it short and factual \u2014 used as a hint, not a hard filter."
          },
          "metadata_filters": {
            "type": "object",
            "additionalProperties": true,
            "description": "Deterministic narrowing applied before ranking. **Top-level keys** are matched against `tenant_metadata` \u2014 they must be declared in the tenant's `tenant_metadata_schema` with `enable_match: true`, otherwise they are silently ignored. To filter on free-form per-document fields, **nest them under a `document_metadata` key**. Both can be combined.",
            "example": {
              "department": "engineering",
              "region": "us-east",
              "document_metadata": {
                "source": "account_plan",
                "author": "alex"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
